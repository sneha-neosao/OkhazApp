<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="10dp"
    android:layout_marginTop="5dp"
    android:layout_marginRight="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="5dp"
            android:elevation="5dp"
            android:layout_marginTop="6dp"
            android:layout_marginLeft="9dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="5dp"
                    android:layout_marginLeft="49dp"
                    >

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O#"
                            android:textSize="12sp"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/colorprimary"
                            />
                        <TextView
                            android:id="@+id/order_no_tv"
                            android:singleLine="true"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1234578"
                            android:textSize="12sp"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/colorprimary"
                            />

                        <TextView
                            android:id="@+id/main_order_no_tv"
                            android:singleLine="true"
                            android:layout_marginLeft="5dp"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(1234578)"
                            android:textSize="12sp"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/colorprimary"
                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="C : "
                            android:singleLine="true"
                            android:gravity="bottom"
                            android:textSize="10sp"
                            app:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/red"
                            />
                        <TextView
                            android:id="@+id/customer_nm_tv"
                            android:text="abcd"
                            android:singleLine="true"
                            android:gravity="bottom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            app:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="T : "
                            android:singleLine="true"
                            android:textSize="10sp"
                            app:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/red"
                            />
                        <TextView
                            android:id="@+id/price_tv"
                            android:text="12345"
                            android:singleLine="true"
                            android:gravity="bottom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llDeviceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:layout_marginTop="5dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="D : "
                            android:singleLine="true"
                            android:textSize="10sp"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="@color/red"
                            />
                        <TextView
                            android:id="@+id/tvDeviceName"
                            android:text=" "
                            android:singleLine="true"
                            android:gravity="bottom"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_supplier_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="6dp"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S : "
                        android:textSize="10sp"
                        android:fontFamily="@font/montserrat_semi_bold"
                        android:textColor="@color/red"
                        />

                    <TextView
                        android:id="@+id/supplier_nm_tv"
                        android:text="abcd"
                        android:gravity="bottom"
                        android:layout_weight="1"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:fontFamily="@font/montserrat_medium"
                        android:textColor="#A0A0A0"
                        />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="top|end"
                android:layout_marginRight="15dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp">


                    <TextView
                        android:id="@+id/time_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="7:40 PM"
                        android:fontFamily="@font/montserrat_medium"
                        android:textSize="8sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_gravity="end"
                    android:gravity="end"
                    android:layout_marginTop="5dp">
                    <TextView
                        android:visibility="gone"
                        android:id="@+id/order_payment_status_tv1"
                        android:layout_width="match_parent"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:textColor="#FF0000"
                        android:gravity="end"
                        android:fontFamily="@font/montserrat_medium"
                        android:text=""
                        android:textSize="10sp" />
                    <TextView
                        android:visibility="visible"
                        android:id="@+id/order_payment_status_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:textColor="#FF0000"
                        android:fontFamily="@font/montserrat_medium"
                        android:text=""
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_marginTop="10dp"
                android:id="@+id/order_status_tv"
                android:background="@drawable/topleft_and_botomright_rounde_green_background"
                android:visibility="visible"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:text="Processing"
                android:gravity="center_horizontal|center_vertical"
                android:layout_gravity="bottom|end"
                android:singleLine="true"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_medium"
                android:textSize="10sp" />


        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/status_img"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/pending_cv"
            android:background="@drawable/rounded_white_bg"
            app:civ_border_width="1dp"
            app:civ_border_color="@color/white"
            android:layout_gravity="center"
            />
    </LinearLayout>

</RelativeLayout>