<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="35dp"
            >

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="5dp"
                android:elevation="5dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:layout_marginLeft="45dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/order_price_tv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Order#3510000"
                            android:fontFamily="@font/montserrat_semi_bold"
                            android:textColor="#004C3F"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Maryam"
                            android:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">
                        <TextView
                            android:id="@+id/order_total_tv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total:AED 15161"
                            android:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/order_qty_tv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:text="Qty:18"
                            android:fontFamily="@font/montserrat_medium"
                            android:textColor="#A0A0A0"
                            android:textSize="10sp"
                            />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="8dp"
                    android:layout_marginRight="15dp"
                    android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/txt_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4/01/2021"
                        android:fontFamily="@font/montserrat_medium"
                        android:textSize="8sp"
                        android:layout_marginRight="7dp"/>

                    <TextView
                        android:id="@+id/txt_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7:40 PM"
                        android:fontFamily="@font/montserrat_medium"
                        android:textSize="8sp" />
                </LinearLayout>


                <TextView
                    android:id="@+id/order_statuses_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textColor="#FF0000"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginTop="6dp"
                    android:text="Unpaid - (COD)"
                    android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:background="@drawable/topleft_and_botomright_rounde_green_background"
                    android:visibility="visible"
                    android:layout_width="120dp"
                    android:layout_height="30dp"
                    android:text="Processing"
                    android:gravity="center_horizontal|center_vertical"
                    android:layout_gravity="bottom|end"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp">
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/status_img"
                android:layout_width="71dp"
                android:layout_height="71dp"
                android:src="@drawable/pending_cv"
                app:civ_border_width="1dp"
                app:civ_border_color="@color/white"
                android:layout_gravity="center"
                />
        </LinearLayout>

</RelativeLayout>