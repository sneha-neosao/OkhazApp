<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal" android:layout_width="match_parent"
    android:layout_height="wrap_content">


    <ImageView
        android:scaleType="centerCrop"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_margin="10sp"
        android:id="@+id/product_iv"/>
    <LinearLayout
        android:layout_marginTop="10sp"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/product_names_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/open_sans_semibold"
            android:maxLines="2"
            android:paddingStart="5dp"
            android:paddingLeft="5dp"
            android:text=""
            android:textColor="@color/colorprimary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/product_prices_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/open_sans"
                android:singleLine="true"
                android:text=""
                android:textSize="10sp" />

            <TextView
                android:id="@+id/product_qty_tv"
                android:background="@color/highlight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/open_sans_bold"
                android:text="qty"
                android:paddingLeft="5dp"
                android:paddingRight="5dp"
                android:paddingBottom="2dp"
                android:layout_marginLeft="10dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/barcode"
                android:textSize="10sp" />

        </LinearLayout>



        <TextView
            android:id="@+id/product_barcode_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/open_sans"
            android:gravity="bottom"
            android:paddingStart="5dp"
            android:paddingLeft="5dp"
            android:singleLine="true"
            android:text=""
            android:textSize="10sp" />
        <TextView
            android:id="@+id/product_suplier_tv"
            android:layout_width="match_parent"
            android:layout_height="13sp"
            android:fontFamily="@font/open_sans"
            android:gravity="center_vertical"
            android:paddingStart="5dp"
            android:paddingLeft="5dp"
            android:singleLine="true"
            android:text=""
            android:textSize="10sp" />


    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_marginStart="20dp"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/barcode"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:id="@+id/barcode_iv"
            android:layout_marginLeft="20dp"
            android:visibility="visible"
            android:layout_alignParentRight="true"
            android:layout_marginRight="10dp" />


        <ImageView
            android:layout_marginStart="20dp"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_add_barcode"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="10dp"
            android:id="@+id/btn_add_barcode"
            android:layout_marginLeft="20dp"
            android:visibility="gone"
            android:layout_alignParentRight="true"
            android:layout_marginRight="10dp" />




    </RelativeLayout>




</LinearLayout>