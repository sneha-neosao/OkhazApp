<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_marginTop="10dp"
    android:layout_marginLeft="5dp"
    android:layout_marginRight="5dp"
    android:backgroundTint="#E5EDEB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="22dp">

        <!--Supplier name-->
        <LinearLayout
            android:id="@+id/ll_supplier_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Supplier name"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/txtSupplierName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />

            </LinearLayout>



        </LinearLayout>

        <!--Supplier address-->
        <LinearLayout
            android:id="@+id/ll_address_supplier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Supplier address"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/txtSupplierAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/navigation_cv"
                android:layout_height="30dp"
                android:layout_width="30dp"
                android:layout_gravity="center"
                app:cardCornerRadius="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_map"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerInParent="true"
                        android:layout_gravity="center"
                        android:src="@drawable/nears"
                        app:tint="@color/colorprimary" />
                </RelativeLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

        <!--Supplier contact-->
        <LinearLayout
            android:id="@+id/ll_supplier_contact_no"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
           >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/contact_no"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/txtSupplierContactNo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_supplier_contact_no"
                android:layout_height="30dp"
                android:layout_width="30dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:layout_gravity="center"
                app:cardCornerRadius="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerInParent="true"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_phone_1"
                        app:tint="@color/colorprimary" />
                </RelativeLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

    </LinearLayout>
        <View
            android:id="@+id/ll_view_supplier_info"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:background="@drawable/dash_bg" />
    <LinearLayout
        android:id="@+id/ll_email_bank_supplier_info"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="25dp">

        <!--Email-->
        <LinearLayout
            android:id="@+id/ll_email_supplier"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp"/>

                <TextView
                    android:id="@+id/tvEmailSupplier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />

            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cv_supplier_email"
                android:layout_height="30dp"
                android:layout_width="30dp"
                android:layout_gravity="center"
                app:cardCornerRadius="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="17dp"
                        android:layout_centerInParent="true"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_mail"
                        app:tint="@color/colorprimary" />
                </RelativeLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>

       <!--Bank Details-->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
            android:id="@+id/ll_bank_details_supplier"
               >

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bank Details"
                    android:fontFamily="@font/montserrat_medium"
                    android:textSize="10sp"
                    android:layout_marginBottom="3dp"/>

                <!--Bank name-->
                <TextView
                    android:id="@+id/txt_subOrder_bankName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />
                <!--Acc no-->
                <TextView
                    android:id="@+id/txt_subOrder_accNum"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />
                <!--Branch-->
                <TextView
                    android:id="@+id/txt_subOrder_accBranch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />
                <!--IFSC-->
                <TextView
                    android:id="@+id/txt_subOrder_ifsc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />
                <!--Bank address-->
                <TextView
                    android:id="@+id/txt_subOrder_bankAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:fontFamily="@font/montserrat_medium"
                    android:textColor="#000000"
                    android:textSize="12sp" />

            </LinearLayout>

    </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/btn_more"
        android:background="@drawable/topleft_and_botomright_rounde_green_background"
        android:visibility="visible"
        android:layout_width="114dp"
        android:layout_height="22dp"
        android:layout_marginTop="8dp"
        android:text="More..."
        android:gravity="center_horizontal|center_vertical"
        android:layout_gravity="bottom|end"
        android:singleLine="true"
        android:textColor="@color/white"
        android:fontFamily="@font/montserrat_medium"
        android:textSize="12sp" />

</androidx.cardview.widget.CardView>