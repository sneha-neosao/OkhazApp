    <LinearLayout
        android:layout_below="@+id/firstRelative"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

   <LinearLayout
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:orientation="vertical">

       <TextView
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:text="Order Id"
           android:textSize="14sp"
           android:textColor="@color/black"
           android:fontFamily="@font/montserrat_medium"
           android:layout_marginBottom="6dp"/>

       <EditText
           android:id="@+id/edt_order_id"
           android:paddingStart="10sp"
           android:textColor="@color/black"
           android:fontFamily="@font/open_sans"
           android:gravity="center_vertical"
           android:singleLine="true"
           android:layout_width="match_parent"
           android:layout_height="35dp"
           android:background="@drawable/square_outline"
           android:layout_marginStart="10dp"
           android:layout_marginEnd="10dp"
           android:paddingLeft="10sp" />

   </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/mediumGrey"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <LinearLayout
            android:id="@+id/llDateFrom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date from"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:fontFamily="@font/montserrat_semi_bold"
                android:layout_marginBottom="6dp"
                />

            <TextView
                android:id="@+id/start_date_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add dates"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:background="@color/white"
                android:textColor="@color/green"
                android:fontFamily="@font/montserrat_medium"
                />

        </LinearLayout>


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentRight="true"
            android:layout_gravity="end">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date to"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:fontFamily="@font/montserrat_semi_bold"
                android:layout_gravity="end"
                android:layout_marginBottom="6dp"
                />

            <TextView
                android:id="@+id/end_date_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add dates"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="@color/green"
                android:background="@color/white"
                android:layout_gravity="end"
                android:fontFamily="@font/montserrat_medium"
                />

        </LinearLayout>


    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/mediumGrey"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Order Status"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:fontFamily="@font/montserrat_medium"
            android:layout_marginBottom="6dp"/>

        <Spinner
            android:id="@+id/status_spiner"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:entries="@array/status"
            android:paddingStart="10sp"
            android:gravity="center_vertical"
            android:paddingLeft="10sp" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_filter_apply"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        app:cornerRadius="20dp"
        android:text="Apply"
        android:backgroundTint="@color/colorprimary"
        android:textSize="14sp"
        app:fontFamily="@font/montserrat_medium"
        android:layout_gravity="center_horizontal"
        android:textAllCaps="false"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="2dp"/>

    </LinearLayout>

    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>