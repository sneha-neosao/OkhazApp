<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context="ae.okhaz.boss.Fragments.OrderDetailsFragment">

    <ProgressBar
        android:id="@+id/pb_details"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/rl_detail"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:orientation="horizontal">

                    <ImageView

                        android:id="@+id/status_img"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        />

                    <LinearLayout
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/order_price_tv"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/open_sans_semibold"
                                android:maxLines="2"
                                android:paddingStart="5dp"
                                android:paddingLeft="5dp"
                                android:text="Amount: ₹ 400.00   (2 Items)  "
                                android:textColor="@color/black"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/order_statuses_tv"
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:fontFamily="@font/open_sans"
                                android:gravity="bottom"

                                android:paddingStart="5dp"
                                android:paddingLeft="5dp"
                                android:singleLine="true"
                                android:text="status: Pending"
                                android:textSize="10sp" />


                        </LinearLayout>


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1">

                        <TextView
                            android:id="@+id/txt_paid"
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:text="UNPAID-(COD)"
                            android:fontFamily="@font/open_sans_semibold"
                            android:gravity="end"
                            android:layout_gravity="end"
                            android:background="@color/highlight"
                            android:paddingStart="5dp"
                            android:layout_marginRight="8dp"
                            android:paddingLeft="10sp"
                            android:paddingEnd="5dp"
                            android:textColor="@color/barcode"
                            android:paddingRight="10sp"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/txt_order_no"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:text="S.O #123456789"
                            android:fontFamily="@font/open_sans_semibold"
                            android:paddingStart="5dp"
                            android:layout_marginTop="5dp"
                            android:gravity="end"
                            android:paddingLeft="10sp"
                            android:paddingEnd="10sp"
                            android:textColor="@color/barcode"
                            android:paddingRight="10sp"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/time_tv"
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:text="27 Nov 2020 8:12:20 PM"
                            android:fontFamily="@font/open_sans"
                            android:gravity="center_vertical|end"
                            android:paddingStart="5dp"
                            android:layout_marginTop="5dp"
                            android:paddingLeft="10sp"
                            android:paddingEnd="5dp"
                            android:layout_marginRight="3dp"
                            android:textColor="@color/pending"
                            android:paddingRight="10sp"
                            android:singleLine="true"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/mo_txt_order_no"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="M.O #123456789 (Accept)"
                    android:fontFamily="@font/open_sans_semibold"
                    android:paddingStart="5dp"
                    android:layout_marginTop="5dp"
                    android:gravity="right"
                    android:layout_gravity="center"
                    android:paddingLeft="10sp"
                    android:textColor="@color/barcode"
                    android:textSize="12sp" />


                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/gray" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:fontFamily="@font/open_sans"
                            android:layout_gravity="center"
                            android:layout_weight="2"
                            android:gravity="center"
                            android:text="Item List"
                            android:layout_marginLeft="10dp"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/img_barcode_switch"
                            android:layout_width="35dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/edit_barcode" />

                        <EditText
                            android:id="@+id/edt_barcode_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:hint="Scan Barcode"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:visibility="visible"
                            />

                        <EditText
                            android:id="@+id/edt_type_barcode_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textColor="@color/black"
                            android:hint="Enter barcode"
                            android:layout_marginLeft="10dp"
                            android:layout_weight="1"
                            android:visibility="gone"
                            />

                        <Button
                            android:id="@+id/btn_edt_scan"
                            android:layout_width="60dp"
                            android:layout_height="45dp"
                            android:textColor="@color/white"
                            android:text="Scan"
                            android:textSize="10sp"
                            android:visibility="gone"
                            android:layout_marginRight="5dp"
                            android:textAllCaps="false"
                            />
                    </LinearLayout>



                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#D3D3D3" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/products_rv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />


                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/gray" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">


                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:paddingStart="10sp"
                            android:layout_weight="2"
                            android:paddingLeft="10sp"
                            android:layout_gravity="center"
                            android:text="Customer Details"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="EDIT"
                            android:drawableRight="@drawable/ic_baseline_edit_24"
                            android:drawableTint="@color/orange_red"
                            android:layout_marginRight="8dp"
                            android:id="@+id/txt_edit"
                            android:textColor="@color/orange_red"
                            android:layout_weight="9"
                            android:layout_gravity="center"
                            android:gravity="center"
                            />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toLeftOf="@id/navigation_cv"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_cust_nmae"
                                style="@style/Order_details_txt"
                                android:layout_width="match_parent"
                                android:layout_height="30dp"
                                android:text="Customer Details"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:paddingStart="10sp"
                                android:paddingLeft="10sp"
                                android:text="Delivery Address"
                                android:textSize="12sp" />


                            <TextView
                                android:id="@+id/tv_cust_address"
                                style="@style/Order_details_txt"
                                android:layout_width="match_parent"
                                android:textStyle="bold"
                                android:layout_height="wrap_content"
                                android:text="Neosao\nNEAR CBS \nKOLHAPUR, 416001, INDIA" />

                        </LinearLayout>


                        <androidx.cardview.widget.CardView
                            android:id="@+id/navigation_cv"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="10dp"
                            android:layout_marginRight="10dp"
                            app:cardCornerRadius="20dp">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical">

                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="25dp"
                                    android:layout_centerInParent="true"
                                    android:layout_gravity="center"
                                    android:src="@drawable/nears"
                                    app:tint="@color/colorprimary" />
                            </RelativeLayout>

                        </androidx.cardview.widget.CardView>


                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_margin="10dp"
                        android:background="@color/gray" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp">

                        <ImageView
                            android:id="@+id/call_iv"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="20dp"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/call"
                            app:tint="@color/colorprimary" />

                        <ImageView
                            android:id="@+id/sms_iv"
                            android:visibility="gone"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="20dp"
                            android:layout_marginRight="20dp"
                            android:layout_toLeftOf="@id/call_iv"
                            android:src="@drawable/sms"
                            app:tint="@color/colorprimary" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toLeftOf="@id/sms_iv"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="10sp"
                                android:paddingLeft="10sp"
                                android:text="Contact Number"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_cust_contact"
                                style="@style/Order_details_txt"
                                android:layout_width="331dp"
                                android:layout_height="20dp"
                                android:text="Contact Number"
                                android:textStyle="bold"

                                />

                        </LinearLayout>

                    </RelativeLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="10dp"
                        android:background="@color/gray" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="5dp">

                        <ImageView
                            android:id="@+id/email_iv"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:layout_marginEnd="20dp"
                            android:layout_marginRight="20dp"
                            android:src="@drawable/email"
                            app:tint="@color/colorprimary" />


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toLeftOf="@id/email_iv"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="10sp"
                                android:paddingLeft="10sp"
                                android:text="Email"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_cust_email"
                                style="@style/Order_details_txt"
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:text="Email Id"
                                android:textStyle="bold"

                                />

                        </LinearLayout>

                    </RelativeLayout>


                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/gray" />



                <RelativeLayout
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white">

                    <TextView
                        android:paddingStart="10sp"
                        android:id="@+id/txtPriceDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Order Details"
                        android:textSize="12sp"
                        tools:ignore="RtlCompat" />

                    <View
                        android:id="@+id/divider1"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_below="@+id/txtPriceDetails"
                        android:layout_marginTop="10dp"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/txtPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/divider1"
                        android:layout_marginTop="10dp"
                        android:text="Subtotal"
                        android:paddingStart="10sp"
                        android:paddingLeft="10sp"
                        style="@style/price_details_txt"/>

                    <TextView
                        android:id="@+id/price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/divider1"
                        android:layout_alignParentRight="true"
                        android:layout_marginTop="10dp"
                        android:layout_marginRight="1dp"
                        android:text="$36.00"
                        style="@style/price_details_txt"
                        />

                    <TextView
                        android:paddingStart="10sp"
                        android:id="@+id/txtDelivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/txtPrice"
                        android:layout_marginTop="10dp"
                        android:text="Shipping &amp; Handling "
                        style="@style/price_details_txt"
                        android:paddingLeft="10sp" />

                    <TextView
                        android:id="@+id/delivery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_below="@+id/txtPrice"
                        android:layout_marginTop="10dp"
                        android:text="$ 0.00"
                        style="@style/price_details_txt" />

                    <TextView
                        android:paddingStart="10sp"
                        android:id="@+id/txtAmountPayable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/txtDiscount"
                        android:layout_marginTop="10dp"
                        android:text="Grand Total "
                        style="@style/price_details_txt"
                        android:paddingLeft="10sp" />

                    <TextView
                        android:id="@+id/amountPayable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_below="@+id/txtDiscount"
                        android:layout_marginTop="10dp"
                        android:text="$36.00"
                        style="@style/price_details_txt" />

                    <TextView
                        android:paddingStart="10sp"
                        android:id="@+id/txtTax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/txtDelivery"
                        android:layout_marginTop="10dp"
                        android:text="Tax"
                        style="@style/price_details_txt"
                        android:paddingLeft="10sp" />

                    <TextView

                        android:id="@+id/tax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_below="@+id/txtDelivery"
                        android:layout_marginTop="10dp"
                        android:text="$0.00"
                        style="@style/price_details_txt"/>


                    <TextView
                        android:paddingStart="10sp"
                        android:id="@+id/txtDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/txtTax"
                        android:layout_marginTop="10dp"
                        android:text="Discount"
                        style="@style/price_details_txt"
                        android:paddingLeft="10sp" />

                    <TextView

                        android:id="@+id/discount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_below="@+id/txtTax"
                        android:layout_marginTop="10dp"
                        android:text="$0.00"
                        style="@style/price_details_txt"/>


                </RelativeLayout>


                <View
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_marginTop="10dp"
                    android:background="@color/gray" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:fontFamily="@font/open_sans"
                            android:gravity="center_vertical"
                            android:paddingStart="10sp"
                            android:paddingLeft="10sp"
                            android:layout_weight="2"
                            android:text="Order Comments"
                            android:textSize="12sp" />

                        <ImageView
                            android:id="@+id/img_arrow_down"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="8"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_baseline_keyboard_arrow_down_24"/>


                        <ImageView
                            android:id="@+id/img_arrow_up"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_weight="8"
                            android:layout_gravity="center"
                            android:visibility="gone"
                            android:src="@drawable/ic_baseline_keyboard_arrow_up_24"/>

                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/gray" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/comments_rv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>


                    <RelativeLayout
                        android:id="@+id/comments_relative"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">


                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/comments_til"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_marginEnd="10dp"
                            android:layout_marginTop="20dp"
                            app:hintTextColor="@color/tomato"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeColor="@color/black"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            >
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/comment_edts"
                                android:layout_width="match_parent"
                                android:layout_height="80dp"
                                android:layout_marginTop="30dp"
                                android:hint="Enter your comment"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:fontFamily="@font/open_sans"
                                />

                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/add_comment"
                            android:layout_below="@id/comments_til"
                            android:layout_width="wrap_content"
                            android:layout_height="55dp"
                            android:text="SUBMIT COMMENT"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_alignParentEnd="true"
                            android:layout_margin="10sp"
                            android:fontFamily="@font/open_sans_semibold"
                            android:layout_alignParentRight="true" />



                    </RelativeLayout>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="5dp"
                        android:layout_marginTop="10dp"
                        android:background="@color/gray" />

                    <Button
                        android:id="@+id/processing_btn"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Accepted"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:layout_alignParentEnd="true"
                        android:layout_margin="10dp"
                        android:fontFamily="@font/open_sans_semibold"
                        android:layout_alignParentRight="true" />





                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        >
                        <LinearLayout
                            android:layout_marginBottom="10dp"
                            android:id="@+id/pending_order_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:layout_gravity="center_vertical"
                                android:layout_weight="1"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:text="PICKUP LOCATION"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:id="@+id/pickedup_location_btn"
                                android:layout_margin="10dp"
                                android:fontFamily="@font/open_sans_semibold"
                                />

                            <Button
                                android:id="@+id/pickedup_btn"
                                android:layout_gravity="center_vertical"
                                android:layout_weight="1"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:text="PICKED UP"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/open_sans_semibold"
                                android:layout_marginRight="10sp" />
                        </LinearLayout>


                        <LinearLayout
                            android:visibility="visible"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:id="@+id/processing_order_view">

                            <Button
                                android:id="@+id/deliver_btn"
                                android:layout_width="match_parent"
                                android:layout_height="55dp"
                                android:text="Deliver"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:layout_alignParentEnd="true"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="10dp"
                                android:layout_marginEnd="10dp"
