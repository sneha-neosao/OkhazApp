<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context="ae.okhaz.boss.Fragments.Admin.SalesFragment">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="13dp"
        android:layout_margin="5dp"
        android:layout_weight="1"
        android:backgroundTint="@color/colorprimary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/txt_lifetimeSale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Life Time Sales"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="normal"
                />

        </LinearLayout>




    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="13dp"
        android:layout_weight="1"
        android:layout_margin="5dp"
        android:backgroundTint="@color/red">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/txt_avgMonthlySale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Average Monthly Sales"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="normal"
                />

        </LinearLayout>




    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/status_chart"
        android:tag="binding_1"
        android:visibility="visible"
        android:layout_margin="10dp"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_sales_today"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Today"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorprimary"
            android:textColor="@color/white"
            android:textSize="11sp"
            />

        <Button
            android:id="@+id/btn_sales_week"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorprimary"
            android:textColor="@color/white"
            android:textSize="11sp"
            />
        <Button
            android:id="@+id/btn_sales_month"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monthly"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorprimary"
            android:textColor="@color/white"
            android:textSize="11sp"
            />
        <Button
            android:id="@+id/btn_sales_year"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yearly"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:backgroundTint="@color/colorprimary"
            android:textColor="@color/white"
            android:textSize="11sp"
            />

    </LinearLayout>

</LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>