<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray"
    tools:context="ae.okhaz.boss.view.activities.ProductListActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar_product"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:navigationIcon="@drawable/ic_back"
                android:background="@color/colorprimary"/>


            <!-- <include layout="@layout/item_layout_supplier_list"/>-->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_product_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_margin="10dp"
                />

            <TextView
                android:visibility="gone"
                android:layout_centerInParent="true"
                android:textSize="17sp"
                android:fontFamily="@font/open_sans_semibold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/no_data_txt"
                android:text="No Products Available..!"
                />

        </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_marginLeft="60dp"
        android:layout_marginRight="10dp"
        android:layout_marginTop="15dp"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/edt_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="3dp"
            android:textSize="16sp"
            android:layout_gravity="center"
            android:textColor="@color/white"
            android:hint="Search"
            android:textColorHint="@color/light_gray"
            android:drawableRight="@drawable/ic_baseline_search_24"
            android:drawableTint="@color/lightGrey"
            android:background="@drawable/square_outline"
            />


    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>