<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="wrap_content"
   >

    <ImageView
        android:id="@+id/btn_close_payment_dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:src="@drawable/ic_baseline_close_24"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:src="@drawable/image_cash"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Do you collect money"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:layout_gravity="center"
        android:layout_marginTop="25dp"
        android:fontFamily="@font/montserrat_bold"
        />

    <TextView
        android:id="@+id/tv_amount_payment_dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AED 25.50"
        android:textSize="32sp"
        android:textColor="@color/colorprimary"
        android:fontFamily="@font/montserrat_bold"
        android:layout_gravity="center"
        android:layout_marginTop="25dp"
        android:layout_marginBottom="25dp"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="40dp">

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:id="@+id/btn_no_payment_dialog"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:text="No"
            android:textColor="@color/black"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_semi_bold"
            />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_yes_payment_dialog"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:text="Yes"
            android:layout_marginLeft="30dp"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_semi_bold"
            android:textAllCaps="false"
            />
    </LinearLayout>

</androidx.appcompat.widget.LinearLayoutCompat>